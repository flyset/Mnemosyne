{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "mnemosyne_memory_remember": "ask"
  },
  "mcp": {
    "mnemosyne": {
      "type": "remote",
      "url": "http://127.0.0.1:8000/mcp",
      "enabled": true
    }
  },
  "agent": {
    "mnemosyne": {
      "permission": {
        "mnemosyne_*": "deny",
        "mnemosyne_list_tools": "allow",
        "mnemosyne_memory_recall": "allow",
        "mnemosyne_memory_remember": "ask"
      }
    }
  }
}
